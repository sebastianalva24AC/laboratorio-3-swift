var metroLima: [String: [String]] = [
    "Línea 1": ["Villa El Salvador", "Atocongo", "San Juan", "Gamarra"],
    "Línea 2": ["Ate", "Santa Anita", "San Luis", "Centro"],
    "Línea 3": ["Comas", "Los Olivos", "San Isidro", "Miraflores"]
]
      
if let estaciones = metroLima["Línea 1"] {
    print("Estaciones Línea 1:", estaciones)
}

let estacionBuscada = "Santa Anita"

for (linea, estaciones) in metroLima {
    if estaciones.contains(estacionBuscada) {
        print("\(estacionBuscada) pertenece a \(linea)")
    }
}

let linea = "Línea 2"
let estacion = "Ate"

if let estaciones = metroLima[linea], estaciones.contains(estacion) {
    print("\(estacion) sí pertenece a \(linea)")
} else {
    print("\(estacion) no pertenece a \(linea)")
}

for (linea, estaciones) in metroLima {
    print("\(linea) tiene \(estaciones.count) estaciones")
}
